# DeepSeek official OpenAI-compatible API settings.
# Docs: https://api-docs.deepseek.com/zh-cn/
#
# Keep these variables server-side. Do not expose DEEPSEEK_API_KEY through
# Vite client env vars such as VITE_DEEPSEEK_API_KEY.

# OpenAI-compatible base URL. Do not include /chat/completions here.
DEEPSEEK_OPENAI_BASE_URL=https://api.deepseek.com

# Secret API key from the DeepSeek platform.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Official V4 Flash model identifier.
DEEPSEEK_MODEL=deepseek-v4-flash

# Thinking mode switch: enabled | disabled
# DeepSeek defaults to enabled if omitted.
DEEPSEEK_THINKING_TYPE=enabled

# Thinking effort in OpenAI-compatible format: high | max
# Use the lowest effective official effort by default.
# Compatibility note from DeepSeek: low/medium map to high, xhigh maps to max.
DEEPSEEK_REASONING_EFFORT=high

# Optional: number of live API calls made by npm run llm:test:deepseek.
DEEPSEEK_TEST_RUNS=8
